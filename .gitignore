# Dependencies
node_modules/
**/node_modules/

# Next.js build output
.next/
out/
next-env.d.ts
*.tsbuildinfo

# App runtime data (SQLite DB lives on the Render disk, not in git)
app/data/*.sqlite
app/data/*.sqlite-shm
app/data/*.sqlite-wal

# Built-in editor: persistent per-repo git workspaces (cloned target repos —
# runtime state on the Render disk, never part of this repo's own history)
app/data/workspaces/

# Python
__pycache__/
*.pyc
.pytest_cache/

# Env & secrets
.env
.env*.local

# Misc
.DS_Store
*.log
